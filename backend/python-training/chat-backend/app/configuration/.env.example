# General project settings
ENVIRONMENT='develop'
PROJECT_NAME='Chat Backend Service'

BACKEND_CORS_ORIGINS=["*"]
BACKEND_CORS_METHODS=["GET", "POST", "PUT", "OPTIONS", "PATCH", "DELETE"]


# PostgreSQL database connection and initialization settings
POSTGRES_SERVER=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=
DB_ECHO=false
DB_INIT=false

READ_ONLY_POSTGRES_SERVER=
READ_ONLY_POSTGRES_USER=
READ_ONLY_POSTGRES_PASSWORD=
READ_ONLY_POSTGRES_DB=
READ_ONLY_POSTGRES_PORT=

# AES-GCM settings
SECRET_ROTATION_KEY_MAPPING={"v1": "0123456789abcdef0123456789abcdef"}
SECRET_CURRENT_VERSION=v1

# Google Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Storage
STORAGE_STRATEGY=local
UPLOAD_DIR=uploads
STORAGE_PRESIGNED_EXPIRES_SECONDS=900
STORAGE_PRESIGNED_GET_EXPIRES_SECONDS=600
DOCUMENT_CV_PREFIX=cv
DOCUMENT_JD_PREFIX=jd

# Cloudflare R2 Settings
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=
R2_REGION=auto

# CV Parser
CV_PARSE_MAX_EXTRACTED_CHARS=12000
CV_PARSE_MAX_HIGHLIGHTS=8
CV_PARSE_MAX_DIAGNOSTICS_IN_ERROR=12
CV_OCR_ENABLED=true
CV_OCR_LANG=vie+eng
CV_OCR_DPI=300
TESSERACT_CMD=
TESSDATA_PREFIX=
CV_PARSE_LEADING_BULLET_PATTERN=^[\s\-\*\>\u00bb\u2022\u2023\u2043\u2219\u25aa\u25ab\u25cf\u25a0\u25e6\u00b7\uf0a7\uf0b7\uf071]+
CV_PARSE_LEADING_SYMBOL_RUN_PATTERN=^[^\w]+(?=\w)

# Match Scoring
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
WEIGHT_SEMANTIC=0.5
WEIGHT_SKILL=0.3
WEIGHT_EXPERIENCE=0.2
